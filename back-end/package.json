  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testEnvironment=node",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testEnvironment=node --watch",
    "start": "nodemon server/server.js",
    "migrate:up": "migrate-mongo up -f migrate-mongo-config.cjs",
    "migrate:down": "migrate-mongo down -f migrate-mongo-config.cjs",
    "migrate:status": "migrate-mongo status -f migrate-mongo-config.cjs",
    "migrate:create": "migrate-mongo create -f migrate-mongo-config.cjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "antd": "^6.3.3",
    "axios": "^1.16.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.77.6",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "migrate-mongo": "^10.0.0",
    "mongoose": "^8.12.1",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.10",
    "nodemon": "^3.0.1",
    "openai": "^6.37.0",
    "redis": "^5.12.1",
    "slugify": "^1.6.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}

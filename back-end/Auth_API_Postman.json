{
  "info": {
    "_postman_id": "auth-api-collection",
    "name": "Auth API Collection",
    "description": "Collection để test các API Authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "item": [
    {
      "name": "1. Sign Up (Đăng ký trực tiếp)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"password123\",\n  \"lastName\": \"Nguyễn\",\n  \"firstName\": \"An\",\n  \"email\": \"an@example.com\",\n  \"birthDate\": \"1990-01-15\"\n}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/signup",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "signup"]
        },
        "description": "Đăng ký tài khoản trực tiếp với đầy đủ thông tin"
      },
      "response": []
    },
    {
      "name": "2. Send Signup Code (Gửi mã xác thực đăng ký)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"password456\",\n  \"lastName\": \"Trần\",\n  \"firstName\": \"Bình\",\n  \"email\": \"binh@example.com\",\n  \"birthDate\": \"1995-05-20\"\n}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/send-signup-code",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "send-signup-code"]
        },
        "description": "Gửi mã OTP xác thực đến email (mã có hiệu lực 60 giây)"
      },
      "response": []
    },
    {
      "name": "3. Verify Signup (Xác thực mã đăng ký)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"binh@example.com\",\n  \"code\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/verify-signup",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "verify-signup"]
        },
        "description": "Xác thực mã OTP và hoàn tất đăng ký (sử dụng sau khi gửi mã)"
      },
      "response": []
    },
    {
      "name": "4. Sign In (Đăng nhập)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"an@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/signin",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "signin"]
        },
        "description": "Đăng nhập với email và password. Trả về accessToken"
      },
      "response": []
    },
    {
      "name": "5. Sign Out (Đăng xuất)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/signout",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "signout"]
        },
        "description": "Đăng xuất và xóa session"
      },
      "response": []
    },
    {
      "name": "6. Check Duplicate (Kiểm tra email/phone tồn tại)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"an@example.com\",\n  \"phone\": \"0901234567\"\n}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/check-duplicate",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "check-duplicate"]
        },
        "description": "Kiểm tra xem email hoặc số điện thoại đã được sử dụng chưa"
      },
      "response": []
    },
    {
      "name": "7. Request Password Reset (Yêu cầu đặt lại mật khẩu)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"an@example.com\"\n}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/request-password-reset",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "request-password-reset"]
        },
        "description": "Yêu cầu gửi mã xác thực đặt lại mật khẩu (mã có hiệu lực 60 phút)"
      },
      "response": []
    },
    {
      "name": "8. Reset Password (Đặt lại mật khẩu)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"an@example.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"newpassword456\"\n}"
        },
        "url": {
          "raw": "http://localhost:5002/api/auth/reset-password",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5002",
          "path": ["api", "auth", "reset-password"]
        },
        "description": "Xác thực mã và đặt lại mật khẩu mới"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5002",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "Lưu accessToken từ signin response"
    },
    {
      "key": "email",
      "value": "an@example.com",
      "type": "string",
      "description": "Email test"
    },
    {
      "key": "password",
      "value": "password123",
      "type": "string",
      "description": "Password test"
    }
  ]
}

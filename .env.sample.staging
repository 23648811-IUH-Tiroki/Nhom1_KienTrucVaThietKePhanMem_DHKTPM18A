# Sample staging environment variables
PORT=3000
MONGO_URI=mongodb://username:password@mongo:27017/your_staging_db
REDIS_URL=redis://:password@redis:6379
JWT_SECRET=replace_with_staging_secret
NODE_ENV=staging
VITE_API_BASE_URL=https://staging-api.example.com
# Optional
EMAIL_HOST=smtp.staging.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
